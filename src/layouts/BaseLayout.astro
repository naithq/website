---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/tailwind.css';

interface Props {
	title: string;
	description?: string;
	/** Webflow page id (`data-wf-page`) - required for Webflow IX2 interactions. */
	pageId: string;
	ogImage?: string;
	showNavbar?: boolean;
	noindex?: boolean;
	/** Extra attributes for `<body>` (e.g. Webflow `data-w-id`). */
	bodyAttrs?: Record<string, string>;
	/** Extra attributes for `.page-wrapper` (e.g. Webflow `data-w-id`). */
	wrapperAttrs?: Record<string, string>;
}

const {
	title,
	description = 'Oman’s flagship sovereign AI platform. World-class AI, 100% Omani-made, aligned with Oman Vision 2040. Enterprise-grade AI with complete data sovereignty.',
	pageId,
	ogImage = '/images/logo-footer.png',
	showNavbar = true,
	noindex = false,
	bodyAttrs = {},
	wrapperAttrs = {},
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const socialImage = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
---

<!doctype html>
<html data-wf-page={pageId} data-wf-site="6a56f7723d4c8a4daf3c58b1" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		{canonical && <link rel="canonical" href={canonical} />}

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImage} />
		<meta property="og:image:secure_url" content={socialImage} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="360" />
		<meta property="og:image:height" content="360" />
		<meta property="og:image:alt" content="National AI Technologies logo" />
		{canonical && <meta property="og:url" content={canonical} />}
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />
		<meta name="twitter:image:alt" content="National AI Technologies logo" />

		<meta name="generator" content={Astro.generator} />

		<link href="/css/normalize.css" rel="stylesheet" type="text/css" />
		<link href="/css/webflow.css" rel="stylesheet" type="text/css" />
		<link href="/css/gulfs-spectacular-site.webflow.css" rel="stylesheet" type="text/css" />
		<link href="/css/i18n.css" rel="stylesheet" type="text/css" />

		<script is:inline type="text/javascript">
			!function (o, c) { var n = c.documentElement, t = " w-mod-"; n.className += t + "js", ("ontouchstart" in o || o.DocumentTouch && c instanceof DocumentTouch) && (n.className += t + "touch") }(window, document);
		</script>
		<script is:inline>
			// Apply saved language direction before first paint (no flash of wrong direction).
			(function () {
				try {
					if (localStorage.getItem("nait-lang") === "ar") {
						document.documentElement.setAttribute("lang", "ar");
						document.documentElement.setAttribute("dir", "rtl");
					}
				} catch (e) { }
			})();
		</script>
		<link rel="preload" href="/i18n/ar.json" as="fetch" crossorigin="anonymous" />

		<link rel="icon" href="/favicon.ico" sizes="48x48" />
		<link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="96x96" href="/icons/favicon-96x96.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#ce0704" />
		<meta name="application-name" content="National AI Technologies" />
		<meta name="apple-mobile-web-app-title" content="NAIT" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="msapplication-TileColor" content="#ce0704" />
		<meta name="msapplication-config" content="/browserconfig.xml" />

		<slot name="head" />
	</head>
	<body {...bodyAttrs}>
		<div class="page-wrapper" {...wrapperAttrs}>
			{showNavbar && <Navbar />}
			<slot />
			<Footer />
		</div>

		<script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=6a56f7723d4c8a4daf3c58b1" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
		<script is:inline src="/js/webflow.js" type="text/javascript"></script>
		<script is:inline src="/js/i18n.js" type="text/javascript"></script>
		<script is:inline>
			// Highlight the current page in the navbar and footer (Webflow "current" state).
			(function () {
				var path = location.pathname.replace(/\/+$/, "") || "/";
				document.querySelectorAll(".navbar a[href], .section.footer a[href]").forEach(function (a) {
					var href = a.getAttribute("href");
					if (href && href.replace(/\/+$/, "") === path || (href === "/" && path === "/")) {
						a.classList.add("w--current");
						a.setAttribute("aria-current", "page");
					}
				});
			})();
		</script>
	</body>
</html>
