  </Fragment>
    <section class="section integration-tools">
      <div class="container section-padding">
        <div data-w-id="0664be6f-ca9b-4963-4ee2-3fbe3472b954" class="integration-section-title-wrapper">
          <div class="subtile-wrapper">
            <div class="subtile-single"><img src="/images/Subtile-Element.svg" loading="lazy" alt="Subtile Icon" class="subtile-icon">
              <div class="subtile">Integration</div>
            </div>
          </div>
          <h1 class="inner-banner-title mb24">Integrated with the best tools to use.</h1>
          <div data-w-id="675e28c1-e1b3-a5c5-0b6d-7ac0f7c31392" class="primary-button-wrapper">
            <a data-wf--primary-button--variant="base" data-w-id="06c54131-d595-78fe-1aa0-c86ac06425eb" href="/contact-us" class="primary-button w-inline-block">
              <div class="primary-button-single in">
                <div class="button-text">Start Free Trial</div><img src="/images/Primary-Button-Arrow.svg" loading="lazy" alt="arrow" class="button-arrow">
              </div>
              <div class="primary-button-single out">
                <div class="button-text">Start Free Trial</div><img src="/images/Primary-Button-Arrow.svg" loading="lazy" alt="arrow" class="button-arrow">
              </div>
            </a>
            <div class="primary-button-shape">
              <div class="primary-button-shape-bg"></div>
            </div>
          </div>
        </div>
        <div class="integration-content">
          <div class="integration-wrapper">
            <div class="integration-tools-icon-wrap one"><img src="/images/Integration-Tools-Icon1.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon one"></div>
            <div class="integration-tools-icon-wrap two"><img src="/images/Integration-Tools-Icon2.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon three"></div>
            <div class="integration-tools-icon-wrap three"><img src="/images/Integration-Tools-Icon3.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon five"></div>
            <div class="integration-tools-icon-wrap main"><img src="/images/Integration-Tools-Icon4.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon main"></div>
            <div class="integration-tools-icon-wrap four"><img src="/images/Features-Banner-Icon2.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon two"></div>
            <div class="integration-tools-icon-wrap five"><img src="/images/Integration-Tools-Icon6.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon four"></div>
            <div class="integration-tools-icon-wrap six"><img src="/images/Integration-Tools-Icon7.svg" loading="lazy" alt="Integration Tools Icon" class="integration-tools-icon six"></div>
          </div>
          <div class="integration-tools-lottie" data-w-id="15c6aeb4-6f5d-af2c-217c-580795b7aac5" data-animation-type="lottie" data-src="/documents/Anim-1-v.2.1.json" data-loop="1" data-direction="1" data-autoplay="1" data-is-ix2-target="0" data-renderer="svg" data-default-duration="8" data-duration="0" data-loading="eager"></div>
        </div>
        <div class="section-line left"></div>
        <div class="section-line right"></div>
      </div>
    </section>
    <section class="section integration">
      <div class="container integration-container">
        <div data-w-id="20343659-e3c7-b6ac-3a6a-fbcc9c1020df" class="integration-main-content">
          <div class="integration-collection-list-wrapper">
            <div role="list" class="integration-collection-list">
              <article role="listitem" class="integration-card-wrapper">
                <div class="integration-card">
                  <div class="integration-card-logo-title">
                    <div class="integration-card-logo-wrap integration-icon-blue"><img src="/images/Integration-Tools-Icon3.svg" loading="lazy" alt="Website and API integration icon" class="integration-card-logo"></div>
                    <h2 class="integration-card-title">Website and API</h2>
                  </div>
                  <p class="integration-card-description">Connect NAIT capabilities to your website, applications, and internal services through secure APIs.</p>
                  <a href="/contact-us" class="integration-card-link-block w-inline-block">
                    <div class="integration-card-link-block-text">Discuss integration</div>
                  </a>
                </div>
              </article>
              <article role="listitem" class="integration-card-wrapper">
                <div class="integration-card">
                  <div class="integration-card-logo-title">
                    <div class="integration-card-logo-wrap integration-icon-green"><img src="/images/Features-Banner-Icon2.svg" loading="lazy" alt="Documents and knowledge integration icon" class="integration-card-logo"></div>
                    <h2 class="integration-card-title">Documents and Knowledge</h2>
                  </div>
                  <p class="integration-card-description">Build trusted AI knowledge from governed documents, data repositories, and institutional content.</p>
                  <a href="/contact-us" class="integration-card-link-block w-inline-block">
                    <div class="integration-card-link-block-text">Discuss integration</div>
                  </a>
                </div>
              </article>
              <article role="listitem" class="integration-card-wrapper">
                <div class="integration-card">
                  <div class="integration-card-logo-title">
                    <div class="integration-card-logo-wrap integration-icon-indigo"><img src="/images/Integration-Tools-Icon6.svg" loading="lazy" alt="Enterprise channels integration icon" class="integration-card-logo"></div>
                    <h2 class="integration-card-title">Enterprise Channels</h2>
                  </div>
                  <p class="integration-card-description">Bring sovereign AI into the communication and operational channels your teams already use.</p>
                  <a href="/contact-us" class="integration-card-link-block w-inline-block">
                    <div class="integration-card-link-block-text">Discuss integration</div>
                  </a>
                </div>
              </article>
            </div>
          </div>
        </div>
        <div class="section-line left"></div>
        <div class="section-line right"></div>
      </div>
    </section>
    <section data-wf--faq--variant="faq-stock-none" class="section faq">
      <div class="container section-padding">
        <div data-w-id="7103a37d-0392-48be-e77e-0e752c877353" class="section-title-wrapper">
          <div class="subtile-wrapper">
            <div class="subtile-single"><img src="/images/Subtile-Element.svg" loading="lazy" alt="Subtile Icon" class="subtile-icon">
              <div class="subtile">Common questions</div>
            </div>
          </div>
          <h2 class="section-title">Frequently asked questions</h2>
        </div>
        <div data-w-id="7103a37d-0392-48be-e77e-0e752c87735b" class="faq-wrapper w-variant-a9658c9a-7fe5-88c7-e026-77522f8b8b78">
          <div class="faq-container">
            <div data-hover="false" data-delay="0" data-w-id="7103a37d-0392-48be-e77e-0e752c87735d" class="faq-single-accordion-wrap w-dropdown">
              <div class="faq-accordion-link w-dropdown-toggle">
                <div class="faq-accordion-title-wrap">
                  <div class="faq-accordion-title">What is National AI Technologies?</div>
                  <div class="faq-accordion-icon-wrapper">
                    <div class="faq-accordion-icon">+</div>
                  </div>
                </div>
              </div>
              <nav class="faq-accordion-ans-wrap w-dropdown-list">
                <div class="faq-accordion-content-wrap">
                  <p class="faq-accordion-ans">National AI Technologies is Oman’s sovereign AI platform, providing secure language models, intelligent automation, and predictive capabilities for government, enterprise, and academia.</p>
                </div>
              </nav>
            </div>
            <div data-hover="false" data-delay="0" data-w-id="7103a37d-0392-48be-e77e-0e752c877368" class="faq-single-accordion-wrap w-dropdown">
              <div class="faq-accordion-link w-dropdown-toggle">
                <div class="faq-accordion-title-wrap">
                  <div class="faq-accordion-title">What does data sovereignty mean at NAIT?</div>
                  <div class="faq-accordion-icon-wrapper">
                    <div class="faq-accordion-icon">+</div>
                  </div>
                </div>
              </div>
              <nav class="faq-accordion-ans-wrap w-dropdown-list">
                <div class="faq-accordion-content-wrap">
                  <p class="faq-accordion-ans">Your data and AI workloads are processed and hosted within Oman on secure national infrastructure, supported by clear governance, robust encryption, and enterprise-grade controls.</p>
                </div>
              </nav>
            </div>
            <div data-hover="false" data-delay="0" data-w-id="7103a37d-0392-48be-e77e-0e752c877373" class="faq-single-accordion-wrap w-dropdown">
              <div class="faq-accordion-link w-dropdown-toggle">
                <div class="faq-accordion-title-wrap">
                  <div class="faq-accordion-title">How can NAIT integrate with our existing systems?</div>
                  <div class="faq-accordion-icon-wrapper">
                    <div class="faq-accordion-icon">+</div>
                  </div>
                </div>
              </div>
              <nav class="faq-accordion-ans-wrap w-dropdown-list">
                <div class="faq-accordion-content-wrap">
                  <p class="faq-accordion-ans">NAIT connects through secure APIs and tailored integration services, allowing your websites, applications, documents, data repositories, and operational channels to work with sovereign AI.</p>
                </div>
              </nav>
            </div>
            <div data-hover="false" data-delay="0" data-w-id="7103a37d-0392-48be-e77e-0e752c87737e" class="faq-single-accordion-wrap w-dropdown">
              <div class="faq-accordion-link w-dropdown-toggle">
                <div class="faq-accordion-title-wrap">
                  <div class="faq-accordion-title">How does NAIT support Arabic and Omani context?</div>
                  <div class="faq-accordion-icon-wrapper">
                    <div class="faq-accordion-icon">+</div>
                  </div>
                </div>
              </div>
              <nav class="faq-accordion-ans-wrap w-dropdown-list">
                <div class="faq-accordion-content-wrap">
                  <p class="faq-accordion-ans">NAIT’s nationally developed language model is trained to understand Arabic, Omani language patterns, and local institutional context for more relevant analysis, summarization, and content creation.</p>
                </div>
              </nav>
            </div>
            <div data-hover="false" data-delay="0" data-w-id="7103a37d-0392-48be-e77e-0e752c877389" class="faq-single-accordion-wrap w-dropdown">
              <div class="faq-accordion-link w-dropdown-toggle">
                <div class="faq-accordion-title-wrap">
                  <div class="faq-accordion-title">How does NAIT protect sensitive information?</div>
                  <div class="faq-accordion-icon-wrapper">
                    <div class="faq-accordion-icon">+</div>
                  </div>
                </div>
              </div>
              <nav class="faq-accordion-ans-wrap w-dropdown-list">
                <div class="faq-accordion-content-wrap">
                  <p class="faq-accordion-ans">NAIT applies layered security, governed access, encryption, and strict operational controls across the full AI lifecycle, from data ingestion to model output.</p>
                </div>
              </nav>
            </div>
            <div data-hover="false" data-delay="0" data-w-id="7103a37d-0392-48be-e77e-0e752c877394" class="faq-single-accordion-wrap last w-dropdown">
              <div class="faq-accordion-link w-dropdown-toggle">
                <div class="faq-accordion-title-wrap">
                  <div class="faq-accordion-title">How do we start a project with NAIT?</div>
                  <div class="faq-accordion-icon-wrapper">
                    <div class="faq-accordion-icon">+</div>
                  </div>
                </div>
              </div>
              <nav class="faq-accordion-ans-wrap w-dropdown-list">
                <div class="faq-accordion-content-wrap">
                  <p class="faq-accordion-ans">Share your objective, data requirements, and desired outcome with our team. We will identify the right sovereign AI capability and define a practical path from discovery to deployment.</p>
                </div>
              </nav>
            </div>
            <div class="section-circle left"></div>
            <div class="section-circle right"></div>
            <div class="section-circle bottom-left"></div>
            <div class="section-circle bottom-right"></div>
          </div>
        </div>
        <div class="section-line left"></div>
        <div class="section-line right"></div>
      </div>
    </section>
    <script is:inline>
      (() => {
        const selector = '.section.faq .faq-accordion-link';
        let lastClickedToggle = null;
        let lastClickTime = 0;

        document.querySelectorAll('.section.faq .faq-single-accordion-wrap').forEach((item, index) => {
          const toggle = item.querySelector('.faq-accordion-link');
          const answer = item.querySelector('.faq-accordion-ans-wrap');
          if (!toggle || !answer) return;
          answer.id = `nait-faq-answer-${index + 1}`;
          item.dataset.faqOpen = 'false';
          toggle.setAttribute('role', 'button');
          toggle.setAttribute('tabindex', '0');
          toggle.setAttribute('aria-controls', answer.id);
          toggle.setAttribute('aria-expanded', 'false');
        });

        const toggleItem = (toggle) => {
          const item = toggle.closest('.faq-single-accordion-wrap');
          if (!item) return;
          const shouldOpen = item.dataset.faqOpen !== 'true';

          document.querySelectorAll('.section.faq .faq-single-accordion-wrap').forEach((otherItem) => {
            otherItem.dataset.faqOpen = 'false';
            otherItem.querySelector('.faq-accordion-link')?.setAttribute('aria-expanded', 'false');
          });

          item.dataset.faqOpen = String(shouldOpen);
          toggle.setAttribute('aria-expanded', String(shouldOpen));
        };

        document.addEventListener('click', (event) => {
          const toggle = event.target.closest?.(selector);
          if (!toggle) return;
          event.preventDefault();
          event.stopImmediatePropagation();
          const clickTime = Date.now();
          if (toggle === lastClickedToggle && clickTime - lastClickTime < 300) return;
          lastClickedToggle = toggle;
          lastClickTime = clickTime;
          toggleItem(toggle);
        }, true);

        document.addEventListener('keydown', (event) => {
          const toggle = event.target.closest?.(selector);
          if (!toggle || (event.key !== 'Enter' && event.key !== ' ')) return;
          event.preventDefault();
          event.stopImmediatePropagation();
          toggleItem(toggle);
        }, true);
      })();
    </script>
    <div class="blank-div-wrapper border-none">
      <div class="container">
        <div class="blank-div">
          <div class="section-circle left"></div>
          <div class="section-circle right"></div>
        </div>
        <div class="section-line left"></div>
        <div class="section-line right"></div>
      </div>
    </div>
</BaseLayout>
