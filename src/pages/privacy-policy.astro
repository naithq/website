    <style is:inline>@media (min-width:992px) {html.w-mod-js:not(.w-mod-ix) [data-w-id="6583dcfe873c33990129c943"] {opacity:0;}html.w-mod-js:not(.w-mod-ix) [data-w-id="ee4c9493-272b-6921-5816-7d90c914124b"] {opacity:0;}html.w-mod-js:not(.w-mod-ix) [data-w-id="38c405f3-8567-b81b-e48a-370a3fa7390c"] {opacity:0;}}</style>
  </Fragment>
    <section class="section main-details">
      <div class="container">
        <div class="details-content">
          <div data-w-id="38c405f3-8567-b81b-e48a-370a3fa7390c" class="details-typography">
            <div class="subtile-wrapper">
              <div class="subtile-single"><img src="/images/Subtile-Element.svg" loading="lazy" alt="Subtile Icon" class="subtile-icon">
                <div class="subtile">Protecting Your Data</div>
              </div>
            </div>
            <div class="privacy-policy-banner-title-wrapper">
              <h1 class="details-banner-title privacy-policy-title-wrapper">Privacy Policy</h1>
