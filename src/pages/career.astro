---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Careers | National AI Technologies"
  description="Join National AI Technologies and help build Oman’s sovereign AI future."
  pageId="6a56f7743d4c8a4daf3c5942"
  bodyAttrs={{"data-w-id": "69410c4dc25d5a71b606b87c"}}
>
  <Fragment slot="head">
    <style is:inline>@media (min-width:992px) {html.w-mod-js:not(.w-mod-ix) [data-w-id="31804296-df11-d90e-8afe-5ad3ecbee1b1"] {opacity:0;}html.w-mod-js:not(.w-mod-ix) [data-w-id="119549fe-7bfb-611b-0959-e2b02fa7af52"] {opacity:0;}html.w-mod-js:not(.w-mod-ix) [data-w-id="69410c4dc25d5a71b606b87c"] {opacity:0;}}</style>
  </Fragment>
    <section class="section inner-banner">
      <div class="container section-padding">
        <div data-w-id="31804296-df11-d90e-8afe-5ad3ecbee1b1" class="inner-banner-typography">
          <div class="subtile-wrapper">
            <div class="subtile-single"><img src="/images/Subtile-Element.svg" loading="lazy" alt="Subtile Icon" class="subtile-icon">
              <div class="subtile">Career</div>
            </div>
          </div>
          <div class="inner-banner-title-description">
            <h1 class="inner-banner-title mb0">Current Opportunities</h1>
          </div>
        </div>
        <div class="section-line left"></div>
        <div class="section-line right"></div>
      </div>
    </section>
    <section class="section career">
      <div class="container career-main">
        <div data-w-id="119549fe-7bfb-611b-0959-e2b02fa7af52" class="career-content">
          <div class="career-collection-list-wrapper w-dyn-list">
            <div role="list" class="career-collection-list w-dyn-items">
              <div role="listitem" class="career-collection-item w-dyn-item">
                <div class="career-single">
                  <div class="career-name-button-wrapper">
                    <a href="#" class="career-name"></a>
                    <div class="primary-button-wrapper">
                      <a data-w-id="119549fe-7bfb-611b-0959-e2b02fa7af5a" href="#" class="primary-button pricing w-inline-block">
                        <div style="-webkit-transform:translate3d(0, 0%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-moz-transform:translate3d(0, 0%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-ms-transform:translate3d(0, 0%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);transform:translate3d(0, 0%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0)" class="primary-button-single in">
                          <div class="button-text">View Detail</div>
                        </div>
                        <div style="-webkit-transform:translate3d(0, 250%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-moz-transform:translate3d(0, 250%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-ms-transform:translate3d(0, 250%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);transform:translate3d(0, 250%, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0)" class="primary-button-single out">
                          <div class="button-text">View Detail</div>
                        </div>
                      </a>
                    </div>
                  </div>
                  <div class="career-card-details-wrapper">
                    <div class="career-card-details-single">
                      <div class="career-card-details-title">Arrangement</div>
                      <div class="career-card-details-text w-dyn-bind-empty"></div>
                    </div>
                    <div class="career-card-details-single">
                      <div class="career-card-details-title">Salary Range</div>
                      <div class="career-card-details-text w-dyn-bind-empty"></div>
                    </div>
                    <div class="career-card-details-single">
                      <div class="career-card-details-title">Location</div>
                      <div class="career-card-details-text w-dyn-bind-empty"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="w-dyn-empty">
              <div>No items found.</div>
            </div>
          </div>
        </div>
        <div class="section-line left"></div>
        <div class="section-line right"></div>
      </div>
    </section>
</BaseLayout>
