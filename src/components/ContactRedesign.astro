<main class="contact-page">
  <section class="contact-hero">
    <div class="contact-hero-heading" data-reveal>
      <div class="contact-kicker">Contact NAIT</div>
      <h1>Building Oman’s intelligent future.</h1>
    </div>
    <div class="contact-hero-footer">
      <p data-reveal="left">Tell us about your institution, the challenge you are solving, and the outcome you need. Our team will connect you with the right sovereign AI capability.</p>
      <a href="mailto:contact@nait.om" class="contact-email-block" data-reveal="right" data-magnetic="10">
        <span>Direct email</span>
        <strong>contact@nait.om</strong>
        <small>Typical response within two business days</small>
      </a>
    </div>
  </section>

  <section class="contact-main">
    <div class="contact-context" data-reveal="left">
      <div class="contact-kicker dark">Start a conversation</div>
      <h2>Share the essentials.</h2>
      <div class="contact-paths" data-reveal-group>
        <div><span>01</span><p>Government and public services</p></div>
        <div><span>02</span><p>Enterprise AI and automation</p></div>
        <div><span>03</span><p>Research and academic partnerships</p></div>
      </div>
    </div>

    <form class="contact-form" id="nait-contact-form" data-reveal="right">
      <div class="contact-field-row">
        <label>Full name<input name="name" type="text" autocomplete="name" required placeholder="Your name" /></label>
        <label>Work email<input name="email" type="email" autocomplete="email" required placeholder="name@organization.om" /></label>
      </div>
      <label>Organization<input name="organization" type="text" autocomplete="organization" placeholder="Organization name" /></label>
      <label>How can we help?<textarea name="message" rows="6" required placeholder="Briefly describe your objective, context, and preferred timeline."></textarea></label>
      <button type="submit">Compose email <span aria-hidden="true">→</span></button>
      <p class="contact-form-note">Submitting opens your email application with the details ready to send to contact@nait.om.</p>
    </form>
  </section>

</main>

<script is:inline>
  document.getElementById('nait-contact-form')?.addEventListener('submit', function (event) {
    event.preventDefault();
    var data = new FormData(event.currentTarget);
    var subject = 'NAIT inquiry from ' + (data.get('organization') || data.get('name'));
    var body = [
      'Name: ' + data.get('name'),
      'Email: ' + data.get('email'),
      'Organization: ' + (data.get('organization') || 'Not provided'),
      '',
      data.get('message')
    ].join('\n');
    location.href = 'mailto:contact@nait.om?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
  });
</script>

<style>
  :global(.contact-page ~ .cta-footer > .section.cta) { display: none; }
  .contact-page { color: #222; background: #f7f7f6; overflow: hidden; }
  .contact-hero { position: relative; overflow: hidden; padding: 138px max(24px, calc((100vw - 1280px) / 2)) 72px; border-bottom: 1px solid #0000001a; background-color: #fafafa; background-image: radial-gradient(#7b797426 1px, transparent 1px); background-size: 18px 18px; }
  .contact-hero-heading, .contact-hero-footer { position: relative; z-index: 1; }
  .contact-hero-heading { max-width: 1080px; }
  .contact-form button { position: relative; overflow: hidden; }
  .contact-form button span { display: inline-block; transition: transform .25s ease; }
  .contact-form button:hover span { transform: translateX(4px); }
  .contact-kicker { margin-bottom: 18px; color: #ce0704; font-size: 12px; line-height: 1.4; font-weight: 700; text-transform: uppercase; }
  .contact-kicker.dark { color: #505050; }
  h1 { max-width: 1000px; margin: 0; color: #222; font-size: clamp(46px, 5vw, 70px); line-height: 1.06; font-weight: 600; text-wrap: balance; }
  .contact-hero-footer { margin-top: 52px; display: grid; grid-template-columns: minmax(0, 1fr) minmax(380px, 440px); gap: clamp(48px, 8vw, 120px); align-items: stretch; }
  .contact-hero-footer > p { max-width: 690px; margin: 0; align-self: center; color: #585858; font-size: 18px; line-height: 1.7; }
  .contact-email-block { min-width: 0; padding: 25px 28px; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 8px 24px; align-items: center; color: #fff; background: #111; border-top: 4px solid #046f36; text-decoration: none; transition: transform .25s ease; }
  .contact-email-block:hover { transform: translateY(-4px); }
  .contact-email-block span, .contact-email-block small { color: #ffffff8f; font-size: 12px; line-height: 1.45; }
  .contact-email-block small { grid-column: 1; }
  .contact-email-block strong { grid-column: 1; grid-row: 2; font-size: clamp(23px, 2.1vw, 29px); line-height: 1.15; font-weight: 500; white-space: nowrap; }
  .contact-email-block::after { content: "→"; grid-column: 2; grid-row: 1 / 4; font-size: 24px; }
  .contact-main { width: min(1280px, calc(100% - 48px)); margin: 0 auto; padding: 104px 0 112px; display: grid; grid-template-columns: minmax(280px, 360px) minmax(0, 1fr); gap: clamp(64px, 8vw, 120px); align-items: start; }
  .contact-context { position: sticky; top: 120px; }
  .contact-context h2 { max-width: 340px; margin: 0; font-size: clamp(30px, 3vw, 42px); line-height: 1.18; text-wrap: balance; }
  .contact-paths { margin-top: 48px; border-top: 1px solid #0000001a; }
  .contact-paths div { padding: 17px 0; display: grid; grid-template-columns: 42px minmax(0, 1fr); align-items: baseline; border-bottom: 1px solid #0000001a; }
  .contact-paths span { color: #ce0704; font-size: 12px; }
  .contact-paths p { min-width: 0; margin: 0; color: #505050; font-size: 15px; line-height: 1.5; }
  .contact-form { min-width: 0; padding: clamp(28px, 4vw, 48px); background: #fff; border: 1px solid #00000012; box-shadow: 0 28px 70px #0000000a; }
  .contact-field-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 28px; }
  .contact-form label { min-width: 0; margin-bottom: 25px; display: flex; flex-direction: column; gap: 8px; color: #222; font-size: 13px; line-height: 1.4; font-weight: 600; }
  .contact-form input, .contact-form textarea { box-sizing: border-box; width: 100%; min-width: 0; padding: 13px 0; color: #222; background: transparent; border: 0; border-bottom: 1px solid #0000002e; border-radius: 0; outline: none; font: inherit; font-size: 15px; line-height: 1.5; font-weight: 400; transition: border-color .2s ease; }
  .contact-form textarea { resize: vertical; min-height: 145px; }
  .contact-form input:focus, .contact-form textarea:focus { border-bottom-color: #046f36; }
  .contact-form button { width: 100%; min-height: 54px; margin-top: 5px; padding: 15px 20px; display: flex; align-items: center; justify-content: space-between; color: #fff; background: #ce0704; border: 0; cursor: pointer; font-size: 15px; font-weight: 600; transition: background-color .2s ease; }
  .contact-form button:hover { background: #a80503; }
  .contact-form-note { max-width: 520px; margin: 13px 0 0; color: #7b7974; font-size: 12px; line-height: 1.55; }
  @media (max-width: 1100px) {
    .contact-hero { padding-top: 120px; }
    .contact-hero-footer { grid-template-columns: minmax(0, 1fr); gap: 34px; }
    .contact-email-block { width: 100%; }
    .contact-main { grid-template-columns: minmax(0, 1fr); gap: 54px; }
    .contact-context { position: static; }
    .contact-context h2 { max-width: none; }
    .contact-paths { margin-top: 34px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); border-bottom: 1px solid #0000001a; }
    .contact-paths div { padding-inline: 16px; grid-template-columns: 34px minmax(0, 1fr); border-inline-end: 1px solid #0000001a; border-bottom: 0; }
    .contact-paths div:first-child { padding-inline-start: 0; }
    .contact-paths div:last-child { padding-inline-end: 0; border-inline-end: 0; }
  }
  @media (max-width: 640px) {
    .contact-hero { padding: 104px 16px 56px; }
    h1 { max-width: 100%; font-size: clamp(34px, 10vw, 40px); line-height: 1.12; }
    .contact-hero-footer { margin-top: 34px; gap: 28px; }
    .contact-hero-footer > p { font-size: 16px; }
    .contact-email-block { padding: 22px 20px; grid-template-columns: minmax(0, 1fr) auto; }
    .contact-email-block strong { font-size: clamp(21px, 6.3vw, 25px); }
    .contact-main { width: calc(100% - 32px); padding: 68px 0 76px; gap: 44px; }
    .contact-paths { display: block; border-bottom: 0; }
    .contact-paths div, .contact-paths div:first-child, .contact-paths div:last-child { padding-inline: 0; grid-template-columns: 38px minmax(0, 1fr); border-inline-end: 0; border-bottom: 1px solid #0000001a; }
    .contact-form { padding: 26px 20px; }
    .contact-field-row { grid-template-columns: 1fr; gap: 0; }
  }
</style>